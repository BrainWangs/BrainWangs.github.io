---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { useTranslations } from "@/i18n";
import { getLocale, localeUrl } from "@/utils/locale";
import config from "@/config";

type AdjacentEntry = {
  /** URL slug for the adjacent post (without locale prefix) */
  slug: string;
  title: string;
} | null;

type Props = {
  prevEntry: AdjacentEntry;
  nextEntry: AdjacentEntry;
};

const { prevEntry, nextEntry } = Astro.props;
const locale = getLocale(Astro.params);
const t = useTranslations(locale);
---

<div data-pagefind-ignore class="my-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
  {
    prevEntry && (
      <a
        href={localeUrl(locale, `posts/${prevEntry.slug}`)}
        class="flex w-full gap-1 hover:opacity-75"
      >
        <IconArrowLeft class="inline-block flex-none rtl:rotate-180" />
        <div>
          <span>{t.post.previousPost}</span>
          <div class="text-accent/85 text-sm">{prevEntry.title}</div>
        </div>
      </a>
    )
  }
  {
    nextEntry && (
      <a
        href={localeUrl(locale, `posts/${nextEntry.slug}`)}
        class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
      >
        <div>
          <span>{t.post.nextPost}</span>
          <div class="text-accent/85 text-sm">{nextEntry.title}</div>
        </div>
        <IconArrowRight class="inline-block flex-none rtl:rotate-180" />
      </a>
    )
  }
</div>
