---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { localePaths, getLocale, localeUrl } from "@/utils/locale";
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostSlug } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

export { localePaths as getStaticPaths };

const locale = getLocale(Astro.params);

// Fetch a few recent posts as recommendations
const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const seen = new Set<string>();
const recentPosts = sortedPosts
  .filter(p => {
    const s = getPostSlug(p.id, p.filePath);
    if (seen.has(s)) return false;
    seen.add(s);
    return true;
  })
  .slice(0, 3);

const t = useTranslations(locale);
const homeUrl = localeUrl(locale);
const postsUrl = localeUrl(locale, "posts");
const searchUrl = localeUrl(locale, "search");
---

<Layout title={`${t.notFound.title} | ${config.site.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center text-center">
      <h1 class="text-accent text-9xl font-bold">404</h1>
      <span aria-hidden="true" class="mt-2 text-2xl"> ¯\_(ツ)_/¯ </span>
      <p class="mt-4 text-2xl sm:text-3xl">{t.notFound.message}</p>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <LinkButton
          href={homeUrl}
          class="rounded-lg bg-accent px-6 py-3 text-accent-foreground font-medium hover:opacity-90"
        >
          {t.notFound.goHome}
        </LinkButton>
        <LinkButton
          href={postsUrl}
          class="rounded-lg border border-border px-6 py-3 font-medium hover:bg-muted"
        >
          {t.pages.postsTitle}
        </LinkButton>
        <LinkButton
          href={searchUrl}
          class="rounded-lg border border-border px-6 py-3 font-medium hover:bg-muted"
        >
          {t.pages.searchTitle}
        </LinkButton>
      </div>

      {
        recentPosts.length > 0 && (
          <section class="mt-12 w-full max-w-lg">
            <h2 class="mb-4 text-xl font-semibold">{t.home.recentPosts}</h2>
            <ul class="space-y-3">
              {recentPosts.map(data => (
                <li class="text-left">
                  <a
                    href={localeUrl(locale, `posts/${getPostSlug(data.id, data.filePath)}`)}
                    class="hover:text-accent underline decoration-dashed underline-offset-4"
                  >
                    {data.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>
