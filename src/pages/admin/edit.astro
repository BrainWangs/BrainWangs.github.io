---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import config from "@/config";

// Astro v7 static mode pre-renders pages by default. A pre-rendered page
// loses access to request-time query params — `Astro.url.searchParams` is
// empty because the page was generated at build time without the runtime
// URL. This is why `slug` was always "" and the edit form never populated.
// Marking the page as server-rendered restores access to the live URL.
export const prerender = false;

if (!import.meta.env.DEV) {
  return new Response("Not found", { status: 404 });
}

const slug = Astro.url.searchParams.get("slug") || "";
---

<Layout title={`Edit ${slug} | Admin | ${config.site.title}`}>
  <Header />
  <main class="app-layout mt-8 pb-12">
    <div class="mb-6 flex items-center gap-4">
      <a href="/admin" class="text-muted-foreground hover:text-accent text-sm"
        >&larr; Dashboard</a
      >
      <h1 class="text-2xl font-semibold sm:text-3xl">
        Edit: <span id="slug-display">{slug}</span>
      </h1>
      <button
        id="delete-btn"
        class="ml-auto rounded bg-red-600 px-3 py-1 text-sm text-white hover:bg-red-700"
        >Delete</button
      >
    </div>

    <div id="loading-msg" class="text-muted-foreground py-4">Loading...</div>

    <div
      id="editor-container"
      style="display:none"
      class="grid grid-cols-1 gap-6 lg:grid-cols-2"
      data-slug={slug}
    >
      <div class="border-border rounded border p-4">
        <h2 class="mb-3 text-lg font-semibold">
          中文版 (zh) <span id="zh-status" class="ml-2 text-xs font-normal"
          ></span>
        </h2>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div>
            <label class="block text-xs">标题</label><input
              id="zh-title"
              type="text"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
          </div>
          <div>
            <label class="block text-xs">发布时间</label><input
              id="zh-date"
              type="datetime-local"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
          </div>
          <div class="col-span-2">
            <label class="block text-xs">描述</label><textarea
              id="zh-desc"
              rows="2"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            ></textarea>
          </div>
          <div>
            <label class="block text-xs">标签 (逗号分隔,可下拉选择)</label><input
              id="zh-tags"
              list="zh-tags-list"
              type="text"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
            <datalist id="zh-tags-list"></datalist>
          </div>
          <div>
            <label class="block text-xs">选项</label><div
              class="mt-1 flex gap-3"
            >
              <label class="flex items-center gap-1 text-xs"
                ><input id="zh-draft" type="checkbox" /> 草稿</label
              ><label class="flex items-center gap-1 text-xs"
                ><input id="zh-featured" type="checkbox" /> 精选</label
              >
            </div>
          </div>
        </div>
        <label class="mt-3 mb-1 block text-xs">正文 (Markdown)</label>
        <textarea
          id="zh-content"
          rows="20"
          class="bg-background border-border w-full rounded border p-2 font-mono text-sm"
        ></textarea>
        <button
          class="toggle-preview text-accent mt-2 text-xs"
          data-textarea="zh-content"
          data-preview="zh-preview">切换预览</button
        >
        <div
          id="zh-preview"
          class="app-prose border-border mt-2 hidden min-h-[100px] rounded border p-3"
        >
        </div>
      </div>
      <div class="border-border rounded border p-4">
        <h2 class="mb-3 text-lg font-semibold">
          English (en) <span id="en-status" class="ml-2 text-xs font-normal"
          ></span>
        </h2>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div>
            <label class="block text-xs">Title</label><input
              id="en-title"
              type="text"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
          </div>
          <div>
            <label class="block text-xs">pubDatetime</label><input
              id="en-date"
              type="datetime-local"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
          </div>
          <div class="col-span-2">
            <label class="block text-xs">Description</label><textarea
              id="en-desc"
              rows="2"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            ></textarea>
          </div>
          <div>
            <label class="block text-xs">Tags (comma-separated, dropdown available)</label><input
              id="en-tags"
              list="en-tags-list"
              type="text"
              class="bg-background border-border w-full rounded border p-1.5 text-sm"
            />
            <datalist id="en-tags-list"></datalist>
          </div>
          <div>
            <label class="block text-xs">Options</label><div
              class="mt-1 flex gap-3"
            >
              <label class="flex items-center gap-1 text-xs"
                ><input id="en-draft" type="checkbox" /> Draft</label
              ><label class="flex items-center gap-1 text-xs"
                ><input id="en-featured" type="checkbox" /> Featured</label
              >
            </div>
          </div>
        </div>
        <label class="mt-3 mb-1 block text-xs">Content (Markdown)</label>
        <textarea
          id="en-content"
          rows="20"
          class="bg-background border-border w-full rounded border p-2 font-mono text-sm"
        ></textarea>
        <button
          class="toggle-preview text-accent mt-2 text-xs"
          data-textarea="en-content"
          data-preview="en-preview">Toggle Preview</button
        >
        <div
          id="en-preview"
          class="app-prose border-border mt-2 hidden min-h-[100px] rounded border p-3"
        >
        </div>
      </div>
    </div>

    <div class="mt-6 flex gap-3">
      <button
        id="save-btn"
        class="bg-accent text-accent-foreground rounded px-6 py-2 hover:opacity-90"
        >Save Changes</button
      >
      <a
        href="/admin"
        class="bg-muted text-muted-foreground rounded px-6 py-2 hover:opacity-90"
        >Back</a
      >
    </div>
    <p id="save-msg" class="mt-3 text-sm"></p>
  </main>
</Layout>

<script>
  function getSlug() {
    return document.getElementById("editor-container")!.dataset.slug!;
  }

  function populateField(prefix: string, fm: Record<string, unknown> | null) {
    if (!fm) return;
    setVal(prefix, "title", fm.title as string);
    setVal(prefix, "desc", fm.description as string);
    if (fm.pubDatetime)
      setVal(
        prefix,
        "date",
        new Date(fm.pubDatetime as string).toISOString().slice(0, 16)
      );
    setVal(
      prefix,
      "tags",
      Array.isArray(fm.tags) ? (fm.tags as string[]).join(", ") : ""
    );
    (document.getElementById(`${prefix}-draft`) as HTMLInputElement).checked =
      !!fm.draft;
    (
      document.getElementById(`${prefix}-featured`) as HTMLInputElement
    ).checked = !!fm.featured;
  }
  function setVal(prefix: string, field: string, val: string) {
    const el = document.getElementById(`${prefix}-${field}`) as
      HTMLInputElement | HTMLTextAreaElement;
    if (el) el.value = val || "";
  }

  async function load() {
    const res = await fetch(`/admin/api/post?slug=${getSlug()}`);
    if (!res.ok) {
      document.getElementById("loading-msg")!.textContent =
        "Error loading post.";
      return;
    }
    const { data } = await res.json();
    document.getElementById("loading-msg")!.style.display = "none";
    document.getElementById("editor-container")!.style.display = "grid";

    populateField("zh", data.zh?.frontmatter);
    setVal("zh", "content", data.zh?.content || "");
    document.getElementById("zh-status")!.innerHTML = data.zh
      ? '<span class="text-green-500">&check; 已存在</span>'
      : '<span class="text-muted-foreground">未创建</span>';

    populateField("en", data.en?.frontmatter);
    setVal("en", "content", data.en?.content || "");
    document.getElementById("en-status")!.innerHTML = data.en
      ? '<span class="text-green-500">&check; exists</span>'
      : '<span class="text-muted-foreground">not created</span>';
  }

  function buildFrontmatter(prefix: string): Record<string, unknown> {
    const fm: Record<string, unknown> = {};
    const t = (document.getElementById(`${prefix}-title`) as HTMLInputElement)
      .value;
    if (t) fm.title = t;
    const d = (document.getElementById(`${prefix}-date`) as HTMLInputElement)
      .value;
    if (d) fm.pubDatetime = new Date(d).toISOString();
    const desc = (
      document.getElementById(`${prefix}-desc`) as HTMLTextAreaElement
    ).value;
    if (desc) fm.description = desc;
    const tags = (document.getElementById(`${prefix}-tags`) as HTMLInputElement)
      .value;
    if (tags)
      fm.tags = tags
        .split(",")
        .map(x => x.trim())
        .filter(Boolean);
    fm.draft = (
      document.getElementById(`${prefix}-draft`) as HTMLInputElement
    ).checked;
    fm.featured = (
      document.getElementById(`${prefix}-featured`) as HTMLInputElement
    ).checked;
    return fm;
  }

  // Populate the zh/en tag <datalist> elements from /admin/api/tags.
  //
  // Failure is non-fatal — if the endpoint errors, the datalists stay empty
  // and the tag inputs degrade to plain text fields (no dropdown suggestions
  // but still fully usable). This matches the design: tag selection is a UX
  // enhancement, not a required step for saving.
  async function loadTagDatalists() {
    try {
      const res = await fetch("/admin/api/tags");
      if (!res.ok) return;
      const { data } = await res.json();
      const zhList = document.getElementById("zh-tags-list");
      const enList = document.getElementById("en-tags-list");
      if (!zhList || !enList) return;
      // Clear any existing options (from a previous page-load cycle).
      zhList.innerHTML = "";
      enList.innerHTML = "";
      for (const tag of data.zh || []) {
        const opt = document.createElement("option");
        opt.value = tag;
        zhList.appendChild(opt);
      }
      for (const tag of data.en || []) {
        const opt = document.createElement("option");
        opt.value = tag;
        enList.appendChild(opt);
      }
    } catch {
      // Network/parse error — leave datalists empty.
    }
  }

  function setupEditPage() {
    // Guard: only run setup on the edit page. `astro:page-load` fires on
    // every navigation (this script is bundled once for the whole site by
    // the ClientRouter), so other admin pages would otherwise throw here.
    const container = document.getElementById("editor-container");
    if (!container) return;
    // Avoid double-binding if setup runs twice on the same DOM (defensive).
    // After a view transition the DOM is fresh, so this attribute won't be
    // set on the new element and setup proceeds normally.
    if (container.dataset.bound === "1") return;
    container.dataset.bound = "1";

    load();
    loadTagDatalists();

    document.getElementById("save-btn")!.addEventListener("click", async () => {
      const body: Record<string, unknown> = {};
      const zhC = (
        document.getElementById("zh-content") as HTMLTextAreaElement
      ).value.trim();
      const enC = (
        document.getElementById("en-content") as HTMLTextAreaElement
      ).value.trim();
      if (zhC) body.zh = { frontmatter: buildFrontmatter("zh"), content: zhC };
      if (enC) body.en = { frontmatter: buildFrontmatter("en"), content: enC };

      const msg = document.getElementById("save-msg")!;
      msg.textContent = "Saving...";
      const res = await fetch(`/admin/api/post?slug=${getSlug()}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      msg.textContent = res.ok ? "Saved!" : `Error: ${data.error}`;
      if (res.ok) setTimeout(() => (msg.textContent = ""), 2000);
    });

    document.getElementById("delete-btn")!.addEventListener("click", async () => {
      if (!confirm(`Delete "${getSlug()}"? This will delete BOTH versions.`))
        return;
      const res = await fetch(`/admin/api/post?slug=${getSlug()}`, {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
      });
      if (res.ok) window.location.href = "/admin";
      else alert(`Error: ${(await res.json()).error}`);
    });

    document.querySelectorAll(".toggle-preview").forEach(btn => {
      btn.addEventListener("click", async () => {
        const textareaId = (btn as HTMLElement).dataset.textarea!;
        const previewId = (btn as HTMLElement).dataset.preview!;
        const preview = document.getElementById(previewId)!;
        if (preview.classList.contains("hidden")) {
          const { marked } = await import("marked");
          preview.innerHTML = marked.parse(
            (document.getElementById(textareaId) as HTMLTextAreaElement).value
          ) as string;
          preview.classList.remove("hidden");
        } else {
          preview.classList.add("hidden");
        }
      });
    });
  }

  // ClientRouter (View Transitions) swaps the DOM on client-side navigation
  // but does NOT re-execute bundled <script> tags. Without listening for
  // `astro:page-load`, the save/delete/preview handlers only attached on a
  // full page reload — navigating from /admin to /admin/edit?slug=... via a
  // link click left #save-btn/#delete-btn with no listener. `astro:page-load`
  // fires both on initial load and after every swap.
  document.addEventListener("astro:page-load", setupEditPage);
</script>
